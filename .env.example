# Netlify environment variables for this project
# Put real values in Netlify Site Settings -> Environment Variables.
# Do not commit secrets to GitHub.

# Supabase database connection for Netlify Functions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Ticket signing and admin auth
QR_JWT_SECRET=
TICKET_DOWNLOAD_SECRET=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_API_KEY=

# Webhook / rate limiting
PAYMENT_WEBHOOK_SECRET=
VALIDATE_RATE_LIMIT_MAX=30
VALIDATE_RATE_LIMIT_WINDOW_MS=60000

# Public site base URL
# Example: https://your-site.netlify.app
SITE_BASE_URL=

# Email delivery
EMAIL_FROM=
RESEND_API_KEY=
BOOKING_NOTIFY_EMAIL=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# WhatsApp delivery
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# M-Pesa / Daraja
MPESA_ENABLED=true
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Optional. If blank, the function will try to use your site URL + /mpesa-callback
MPESA_CALLBACK_URL=
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
